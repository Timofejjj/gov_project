# 1) Скопируйте этот файл в .env и подставьте токен: https://huggingface.co/settings/tokens
# 2) Под тем же аккаунтом откройте и примите условия (кнопка Agree) хотя бы на одной странице:
#    https://huggingface.co/pyannote/speaker-diarization-3.1
#    https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=hf_your_token_here
# Транскрипция AssemblyAI (streaming): https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# --- LLM постобработка спикеров (опционально) ---
# Groq (если задан только GROQ_API_KEY — используется Groq SDK)
GROQ_API_KEY=your_groq_key_here
# OpenAI-совместимый API (если задан OPENAI_API_KEY — используется пакет openai)
OPENAI_API_KEY=your_openai_key_here
# Необязательно: кастомный base URL для OpenAI-совместимых прокси
OPENAI_BASE_URL=

# Модель (для Groq обычно нужен префикс провайдера, напр. openai/gpt-oss-120b)
LLM_MODEL=
# USE_LLM=0 полностью отключает авто-включение LLM даже при наличии ключей
USE_LLM=1
# LLM_SECOND_PASS=0 отключает второй проход refine
LLM_SECOND_PASS=1
NUM_SPEAKERS=
